pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    environment {
        APP_NAME = "achat"
        SONAR_TOKEN = credentials('sonar-token')
        NVD_API_KEY = credentials('nvd-api-key')
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        timestamps()
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'badiss',
                    url: 'https://github.com/GhassenAhmed/DevOps'
            }
        }

        stage('Build & Tests') {
            steps {
                dir('achat/achat') {
                    sh '''
                        mvn clean verify \
                        -Dmaven.test.failure.ignore=false
                    '''
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('achat/achat') {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                            mvn sonar:sonar \
                            -Dsonar.projectKey=achat \
                            -Dsonar.projectName=achat
                        '''
                    }
                }
            }
        }

        stage('Package') {
            steps {
                dir('achat/achat') {
                    sh 'mvn package -DskipTests'
                }
            }
        }

        stage('OWASP Dependency Check') {
            steps {
                dir('achat/achat') {

                    sh '''
                        mvn org.owasp:dependency-check-maven:check \
                        -DnvdApiKey=$NVD_API_KEY \
                        -Dformats=HTML \
                        -DfailBuildOnCVSS=11
                    '''
                }
            }

            post {
                always {
                    publishHTML(target: [
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'achat/achat/target',
                        reportFiles: 'dependency-check-report.html',
                        reportName: 'OWASP Dependency Check Report'
                    ])
                }
            }
        }

        stage('Nexus Deploy') {
            steps {
                dir('achat/achat') {

                    withCredentials([usernamePassword(
                        credentialsId: 'nexus-credentials',
                        usernameVariable: 'NEXUS_USER',
                        passwordVariable: 'NEXUS_PASS'
                    )]) {

                        sh """
                            mvn deploy -DskipTests \
                            -DaltDeploymentRepository=nexus::default::http://${NEXUS_USER}:${NEXUS_PASS}@localhost:8081/repository/maven-snapshots/
                        """
                    }
                }
            }
        }
    }

    post {

        success {
            echo 'Build réussi 🎉'
        }

        failure {
            echo 'Build échoué ❌'
        }

        always {
            archiveArtifacts artifacts: 'achat/achat/target/*.jar', fingerprint: true
            echo 'Pipeline terminé'
        }
    }
}