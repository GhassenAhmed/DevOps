pipeline {
    agent any

    environment {
        IMAGE_NAME = 'achat-app'
        IMAGE_TAG  = "${BUILD_NUMBER}"
        MVN = '/var/jenkins_home/tools/hudson.tasks.Maven_MavenInstallation/Maven3/bin/mvn'
        NEXUS_URL = 'http://172.17.0.1:8081'
        NEXUS_REPO = 'maven-releases'
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Docker Permission') {
            steps {
                sh 'chmod 666 /var/run/docker.sock || true'
            }
        }

        stage('Build') {
            steps {
                dir('achat/achat') {
                    sh '${MVN} clean package -DskipTests -B'
                }
            }
        }

        stage('Test') {
            steps {
                dir('achat/achat') {
                    sh '${MVN} test -B'
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir('achat/achat') {
                    withSonarQubeEnv('Sonar') {
                        sh '${MVN} sonar:sonar'
                    }
                }
            }
        }

        stage('Nexus Deploy') {
            steps {
                dir('achat/achat') {
                    sh """
                        ${MVN} deploy -DskipTests -B \
                        -s /var/jenkins_home/.m2/settings.xml \
                        -DaltDeploymentRepository=nexus-releases::default::${NEXUS_URL}/repository/${NEXUS_REPO}
                    """
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('achat/achat') {
                    sh "docker build -t ${IMAGE_NAME}:${IMAGE_TAG} ."
                }
            }
        }

        stage('Docker Test') {
            steps {
                sh """
                    set -e

                    echo "🧹 Cleanup old container..."
                    docker rm -f test-${BUILD_NUMBER} || true

                    echo "🐳 Start container..."
                    docker run -d --name test-${BUILD_NUMBER} \
                      -p 18080:8080 \
                      --network achat_devops-net \
                      -e SPRING_DATASOURCE_URL=jdbc:mysql://devops-db:3306/achatdb?createDatabaseIfNotExist=true \
                      -e SPRING_DATASOURCE_USERNAME=root \
                      -e SPRING_DATASOURCE_PASSWORD=root \
                      ${IMAGE_NAME}:${IMAGE_TAG}

                    echo "⏳ Waiting for MySQL connection..."

                    for i in $(seq 1 20); do
                        docker exec devops-db mysqladmin ping -h localhost --silent && break
                        echo "MySQL not ready yet..."
                        sleep 3
                    done

                    echo "⏳ Waiting for Spring Boot health..."

                    for i in $(seq 1 30); do
                        RESPONSE=$(curl -s --max-time 3 http://localhost:18080/actuator/health || true)

                        echo "Attempt $i - $RESPONSE"

                        echo "$RESPONSE" | grep -q '"status":"UP"'
                        if [ \$? -eq 0 ]; then
                            echo "✅ Application is UP"
                            exit 0
                        fi

                        sleep 5
                    done

                    echo "❌ Timeout - application not ready"
                    docker logs test-${BUILD_NUMBER}
                    exit 1
                """
            }

            post {
                always {
                    sh 'docker rm -f test-${BUILD_NUMBER} || true'
                }
            }
        }

        stage('Docker Deploy') {
            steps {
                dir('achat/achat') {
                    sh 'docker compose up -d --no-deps --build app'
                }
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline SUCCESS'
        }
        failure {
            echo '❌ Pipeline FAILED'
        }
    }
}
