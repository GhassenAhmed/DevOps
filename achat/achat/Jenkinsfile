pipeline {
    agent any

    tools {
        //jdk 'JDK8'          // IMPORTANT: Java 1.8 dans ton pom.xml
        maven 'Maven'       // Nom configuré dans Jenkins
    }

    environment {
        APP_NAME = "achat"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'badiss',
                    url: 'https://github.com/GhassenAhmed/DevOps'
            }
        }

        stage('Build') {
            steps {
                dir('achat/achat') {
                    sh 'mvn clean compile'
                }
            }
        }

        stage('Tests') {
            steps {
                dir('achat/achat') {
                    sh 'mvn test'
                }
            }
        }

        stage('Package') {
            steps {
                dir('achat/achat') {
                    sh 'mvn package -DskipTests'
                }
            }
        }

    }

    post {
        success {
            echo 'Build réussi 🎉'
        }
        failure {
            echo 'Build échoué ❌'
        }
        always {
            echo 'Pipeline terminé'
        }
    }
}