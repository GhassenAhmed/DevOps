pipeline {
    agent any
    environment {
        IMAGE_NAME = 'achat-app'
        IMAGE_TAG  = "${BUILD_NUMBER}"
        MVN = '/var/jenkins_home/tools/hudson.tasks.Maven_MavenInstallation/Maven3/bin/mvn'
        NEXUS_URL = 'http://172.17.0.1:8081'
        NEXUS_REPO = 'maven-releases'
    }
    stages {

        stage('Checkout') {
            steps {
                echo '📥 Récupération du code...'
                checkout scm
            }
        }

        stage('Docker Permission') {
            steps {
                sh 'chmod 666 /var/run/docker.sock || true'
            }
        }

        stage('Build') {
            steps {
                echo '🔨 Build Maven...'
                dir('achat/achat') {
                    sh '${MVN} clean package -DskipTests -B'
                }
            }
        }

        stage('Test') {
            steps {
                echo '🧪 Tests unitaires...'
                dir('achat/achat') {
                    sh '${MVN} test -B'
                }
            }
        }

        stage('OWASP Dependency Check') {
            steps {
                echo '🔒 Scan OWASP des dépendances...'
                dir('achat/achat') {
                    sh '''
                        ${MVN} org.owasp:dependency-check-maven:check \
                            -DfailBuildOnCVSS=11 \
                            -DskipSystemScope=true \
                            -Dformats=HTML,XML \
                            -DoutputDirectory=./dependency-check-report || true
                    '''
                }
            }
            post {
                always {
                    dependencyCheckPublisher(
                        pattern: 'achat/achat/dependency-check-report/dependency-check-report.xml',
                        failedTotalCritical: 0,
                        unstableTotalHigh: 10
                    )
                }
            }
        }

        stage('SonarQube Analysis') {
            steps {
                echo '🔍 Analyse SonarQube...'
                dir('achat/achat') {
                    withSonarQubeEnv('Sonar') {
                        sh '${MVN} sonar:sonar'
                    }
                }
            }
        }

        stage('Quality Gate') {
            steps {
                echo '🚦 Vérification Quality Gate...'
                timeout(time: 2, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: false
                }
            }
        }

        stage('Nexus Deploy') {
            steps {
                echo '📦 Publication vers Nexus...'
                dir('achat/achat') {
                    sh '''
                        ${MVN} deploy -DskipTests -B \
                        -s /var/jenkins_home/.m2/settings.xml \
                        -DaltDeploymentRepository=nexus-releases::default::${NEXUS_URL}/repository/${NEXUS_REPO}
                    '''
                }
            }
        }

        stage('Docker Build') {
            steps {
                echo '🐳 Construction image Docker...'
                dir('achat/achat') {
                    sh 'docker build -t ${IMAGE_NAME}:${IMAGE_TAG} .'
                    sh 'docker tag ${IMAGE_NAME}:${IMAGE_TAG} ${IMAGE_NAME}:latest'
                }
            }
        }

        stage('Trivy Scan') {
            steps {
                echo '🔒 Scan Trivy de l\'image Docker...'
                sh '''
                    trivy image \
                        --severity HIGH,CRITICAL \
                        --format table \
                        --exit-code 0 \
                        ${IMAGE_NAME}:${IMAGE_TAG}
                '''
            }
        }

        stage('Docker Test') {
            steps {
                echo '🧪 Test du conteneur...'
                sh '''
                    docker rm -f test-${BUILD_NUMBER} || true

                    docker run -d --name test-${BUILD_NUMBER} \
                      --network achat_devops-net \
                      -e SPRING_DATASOURCE_URL=jdbc:mysql://devops-db:3306/achatdb?createDatabaseIfNotExist=true \
                      -e SPRING_DATASOURCE_USERNAME=root \
                      -e SPRING_DATASOURCE_PASSWORD=root \
                      ${IMAGE_NAME}:${IMAGE_TAG}

                    echo "⏳ Attente du démarrage (90s max)..."
                    for i in $(seq 1 18); do
                        if curl -sf http://test-${BUILD_NUMBER}:8080/actuator/health > /dev/null 2>&1; then
                            echo "✅ Application démarrée !"
                            exit 0
                        fi
                        echo "  Tentative $i/18 - attente 5s..."
                        sleep 5
                    done
                    echo "❌ Timeout"
                    docker logs test-${BUILD_NUMBER}
                    exit 1
                '''
            }
            post {
                always {
                    sh 'docker rm -f test-${BUILD_NUMBER} || true'
                }
            }
        }

        stage('Docker Deploy') {
            steps {
                echo '🚀 Déploiement avec Docker Compose...'
                dir('achat/achat') {
                    sh 'docker-compose up -d --no-deps --build app'
                }
            }
        }
    }

    post {
        success {
            echo '✅ Pipeline terminé avec succès !'
        }
        failure {
            echo '❌ Pipeline échoué !'
        }
        always {
            echo '🏁 Pipeline finished'
        }
    }
}
